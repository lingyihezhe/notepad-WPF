<Window x:Class="notepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:notepad"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:notepad.ViewModel"
        WindowStartupLocation = "CenterScreen"
        d:DataContext="{d:DesignInstance vm:ViewModelLocator, IsDesignTimeCreatable=False}"
        mc:Ignorable="d"
        Title="{Binding DocumentM.DocTitle}" Height="450" Width="600">
            <!-- d: 允许延时创建datacontext实例，方便语法检查 -->
    <!-- 按键binding -->
    <Window.InputBindings>
        <!-- 字体增大 -->
        <KeyBinding Key="OemPlus"
                    Modifiers="Control"
                    Command="{Binding FontVm.FontSizeIncreaseCommand}"/>
        <!-- 字体减小 -->
        <KeyBinding Key="OemMinus"
                    Modifiers="Control"
                    Command="{Binding FontVm.FontSizeDecreaseCommand}"/>
        <!-- 打开 -->
        <KeyBinding Key="O"
                    Modifiers="Control+Shift"
                    Command="{Binding FileVm.OpenFileCommand}"/>
        <!-- 新建 -->
        <KeyBinding Key="N"
                    Modifiers="Control+Shift"
                    Command="{Binding FileVm.CloseFileCommand}"/>
        <!-- 保存 -->
        <KeyBinding Key="S"
                    Modifiers="Control"
                    Command="{Binding FileVm.SaveFileCommand}"
                    CommandParameter="{Binding ElementName=MainTextBox}"/>
        <!-- 另存为 -->
        <KeyBinding Key="S"
                    Modifiers="Control+Shift"
                    Command="{Binding FileVm.SaveAsFileCommand}"
                    CommandParameter="{Binding ElementName=MainTextBox}"/>
        <!-- 关闭文件 -->
        <KeyBinding Key="C"
                    Modifiers="Control+Shift"
                    Command="{Binding FileVm.CloseFileCommand}"/>
    </Window.InputBindings>
    
    <DockPanel>
        <!-- 菜单栏 -->
        <Menu DockPanel.Dock="Top"
              Height="auto">
            <!-- 文件 -->
            <MenuItem Header="文件(_F)">
                <MenuItem Header="打开"
                          Command="{Binding FileVm.OpenFileCommand}"
                          InputGestureText="Control+Shift+O"/>
                
                <MenuItem Header="新建"
                          Command="{Binding FileVm.CloseFileCommand}"
                          InputGestureText="Control+Shift+N"/>
                
                <MenuItem Header="保存"
                          Command="{Binding FileVm.SaveFileCommand}"
                          CommandParameter="{Binding ElementName=MainTextBox}"
                          InputGestureText="Control+S"/>
                
                <MenuItem Header="另存为"
                          Command="{Binding FileVm.SaveAsFileCommand}"
                          CommandParameter="{Binding ElementName=MainTextBox}"
                          InputGestureText="Control+Shift+S"/>
                
                <MenuItem Header="关闭"
                          Command="{Binding FileVm.CloseFileCommand}"
                          InputGestureText="Control+Shift+C"/>
            </MenuItem>
            <!-- 编辑 -->
            <MenuItem Header="编辑(_E)">
                <MenuItem Header="撤销" Command="ApplicationCommands.Undo" />
                <MenuItem Header="重做" Command="ApplicationCommands.Redo" />
                <MenuItem Header="剪切" Command="ApplicationCommands.Cut" />
                <MenuItem Header="复制" Command="ApplicationCommands.Copy" />
                <MenuItem Header="粘贴" Command="ApplicationCommands.Paste" />
                <MenuItem Header="全选" Command="ApplicationCommands.SelectAll" />
            </MenuItem>
            <!-- 视图 -->
            <MenuItem Header="视图(_V)">
                <MenuItem Header="字体"
                          Command="{Binding  ViewVm.ShowFontCommand}"
                          InputGestureText="Control+Shift+F"/>
                
                <MenuItem Header="自动换行"
                          IsCheckable="True"
                          IsChecked="{Binding DocumentM.IsWrapped}"/>
                
                <MenuItem Header="状态栏"
                          IsCheckable="True"
                          IsChecked="{Binding DocumentM.IsStatusBarVisible}"/>
            </MenuItem>
            <!-- 关于 -->
            <MenuItem Header="关于(_A)"
                      Command="{Binding AboutVm.ShowAboutCommand}"/>
        </Menu> 
        <!-- 状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" 
                   Height="24" 
                   Visibility="{Binding DocumentM.StatusBarVisible}">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- 编码 -->
                            <ColumnDefinition Width="Auto"/>   <!-- 状态（已保存/未保存） -->
                            <ColumnDefinition Width="*"/>      <!-- 弹性占位，将右侧内容推至最右 -->
                            <ColumnDefinition Width="Auto"/>   <!-- 行列信息 -->
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <!-- 编码信息 -->
            <StatusBarItem Grid.Column="0" Margin="8,0,4,0">
                <TextBlock Text="{Binding DocumentM.DocEncodingName}"/>
            </StatusBarItem>
            <!-- 总字数 -->
            <StatusBarItem Grid.Column="1" Margin="4,0">
                <TextBlock Text="{Binding DocumentM.DocLengthStatus}"/>
            </StatusBarItem>
            <!-- 占位 -->
            <StatusBarItem Grid.Column="2"/>
            <!-- 行列信息 -->
            <StatusBarItem Grid.Column="3" Margin="4,0,8,0">
                <TextBlock Text="{Binding DocumentM.DocCurrentPosition}"/>
            </StatusBarItem>
        </StatusBar>
        <!-- 编辑区 -->
        <TextBox Text="{Binding DocumentM.DocString}"
                 x:Name="MainTextBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="{Binding DocumentM.TextWrap}"
                 FontSize="{Binding DocumentM.FontSize}"
                 FontFamily="{Binding DocumentM.FontFamily}">
            <i:Interaction.Triggers>
                <!-- 文本变化 -->
                <i:EventTrigger EventName="TextChanged">
                    <i:InvokeCommandAction Command="{Binding FileVm.TextChangedCommand}"
                                           CommandParameter="{Binding Text.Length, ElementName=MainTextBox}"/>
                </i:EventTrigger>
                <!-- 光标位置变化 -->
                <i:EventTrigger EventName="SelectionChanged">
                    <i:InvokeCommandAction Command="{Binding FileVm.UpdateCaretPositionCommand}"
                                           CommandParameter="{Binding ElementName=MainTextBox}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </TextBox>
    </DockPanel>
</Window>
