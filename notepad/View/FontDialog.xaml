<Window x:Class="notepad.View.FontDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:vm="clr-namespace:notepad.ViewModel"
        WindowStartupLocation = "CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        d:DataContext="{d:DesignInstance vm:ViewModelLocator, IsDesignTimeCreatable=False}"
        Title="字体" Height="220" Width="240">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="字体大小"
                   TextAlignment="Center"
                   FontSize="16"/>
        
        <DockPanel Grid.Row="2" Margin="20,0,20,0">
            <Button DockPanel.Dock="Left"
                    Height="30"
                    Width="40"
                    Content="-"
                    FontSize="20"
                    Command="{Binding FontVm.FontSizeDecreaseCommand}"/>
            
            <Button DockPanel.Dock="Right"
                    Height="30"
                    Width="40"
                    Content="+"
                    FontSize="20"
                    Command="{Binding FontVm.FontSizeIncreaseCommand}"/>
            
            <TextBox Text="{Binding DocumentM.FontSize}"
                     Height="30"
                     FontSize="25"
                     TextAlignment="Center"/>
        </DockPanel>
        
        <TextBlock Grid.Row="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="字体家族"
                   TextAlignment="Center"
                   FontSize="16"/>
        
        <DockPanel Grid.Row="4" Margin="20,0,20,0">
            <ComboBox DockPanel.Dock="Left"
                      Height="30"
                      Width="140"
                      VerticalContentAlignment="Center"
                      HorizontalContentAlignment="Center"
                      ItemsSource="{Binding  DocumentM.SystemFontFamilies}" 
                      SelectedItem="{Binding  DocumentM.FontFamily}"
                      DisplayMemberPath="Source" />
            
            <Button DockPanel.Dock="Right"
                    Height="30"
                    Width="40"
                    Content="重置"
                    Command="{Binding FontVm.FontSetDefaultCommand}"/>
        </DockPanel>
    </Grid> 
</Window>
