<Window x:Class="notepad.View.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:notepad.View"
        xmlns:vm="clr-namespace:notepad.ViewModel"
        d:DataContext="{d:DesignInstance vm:ViewModelLocator, IsDesignTimeCreatable=False}"
        WindowStartupLocation = "CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        mc:Ignorable="d"
        Title="关于" Height="320" Width="240">
    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top">
        <Image Source="/Asset/Image/About/about.png" Width="100" Height="100" Margin="40,25,40,0"/>
        <TextBlock Text="notepad#" TextAlignment="Center" FontSize="24"/>
        <TextBlock Text="一个WPF框架的记事本" TextAlignment="Center" FontSize="16" Margin="5"/>
        <TextBlock Text="版本：0.1" TextAlignment="Center" FontSize="16" />
        <TextBlock Text="lingyi" TextAlignment="Center" FontSize="16"/>
        <Button Content="MIT LICENSE" Margin="0,10,0,0"
                Width="120"
                Click="OnMitLicenseClick"/>
    </StackPanel>
</Window>
